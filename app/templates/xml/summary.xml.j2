<?xml version="1.0" encoding="utf-8" standalone="no"?>
{#
  Plantilla UBL 2.0 Resumen Diario (RC) SUNAT Perú
  Fiel traducción de summary.blade.php de CoreFacturalo.

  Variables específicas:
    document.identifier        → identificador del batch (ej. RC-20230101-1)
    document.date_of_reference → fecha de referencia
    document.date_of_issue     → fecha de generación
    document.documents         → lista de comprobantes del resumen
      doc.series / doc.number / doc.document_type_id
      doc.customer             → {number, identity_document_type_id, name}
      doc.currency_type_id
      doc.status               → codigo de estado (1=Adicionar, 2=Modificar, 3=Anular)
      doc.total_taxed / doc.total_exonerated / doc.total_unaffected
      doc.total_exportation / doc.total_free
      doc.total_taxes / doc.total_igv / doc.total_isc / doc.total_other_taxes
      doc.total_plastic_bag_taxes / doc.total_ivap / doc.total
      doc.note                 → para notas (07/08): {affected_series, affected_number, affected_document_type_id}
      doc.perception           → {internal_id, amount} si aplica
#}
<SummaryDocuments
    xmlns="urn:sunat:names:specification:ubl:peru:schema:xsd:SummaryDocuments-1"
    xmlns:cac="urn:oasis:names:specification:ubl:schema:xsd:CommonAggregateComponents-2"
    xmlns:cbc="urn:oasis:names:specification:ubl:schema:xsd:CommonBasicComponents-2"
    xmlns:ds="http://www.w3.org/2000/09/xmldsig#"
    xmlns:ext="urn:oasis:names:specification:ubl:schema:xsd:CommonExtensionComponents-2"
    xmlns:sac="urn:sunat:names:specification:ubl:peru:schema:xsd:SunatAggregateComponents-1"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
    <ext:UBLExtensions>
        <ext:UBLExtension>
            <ext:ExtensionContent/>
        </ext:UBLExtension>
    </ext:UBLExtensions>
    <cbc:UBLVersionID>2.0</cbc:UBLVersionID>
    <cbc:CustomizationID>1.1</cbc:CustomizationID>
    <cbc:ID>{{ document.identifier }}</cbc:ID>
    <cbc:ReferenceDate>{{ document.date_of_reference }}</cbc:ReferenceDate>
    <cbc:IssueDate>{{ document.date_of_issue }}</cbc:IssueDate>
    <cac:Signature>
        <cbc:ID>{{ company.signature_uri or 'IDFirma' }}</cbc:ID>
        <cbc:Note>{{ company.signature_note or 'Empresa emisora' }}</cbc:Note>
        <cac:SignatoryParty>
            <cac:PartyIdentification>
                <cbc:ID>{{ company.legal_number }}</cbc:ID>
            </cac:PartyIdentification>
            <cac:PartyName>
                <cbc:Name><![CDATA[{{ company.trade_name }}]]></cbc:Name>
            </cac:PartyName>
        </cac:SignatoryParty>
        <cac:DigitalSignatureAttachment>
            <cac:ExternalReference>
                <cbc:URI>#{{ company.signature_uri or 'IDFirma' }}</cbc:URI>
            </cac:ExternalReference>
        </cac:DigitalSignatureAttachment>
    </cac:Signature>
    <cac:AccountingSupplierParty>
        <cbc:CustomerAssignedAccountID>{{ company.legal_number }}</cbc:CustomerAssignedAccountID>
        <cbc:AdditionalAccountID>6</cbc:AdditionalAccountID>
        <cac:Party>
            <cac:PartyLegalEntity>
                <cbc:RegistrationName><![CDATA[{{ company.legal_name }}]]></cbc:RegistrationName>
            </cac:PartyLegalEntity>
        </cac:Party>
    </cac:AccountingSupplierParty>
    {% for doc in document.documents %}
    <sac:SummaryDocumentsLine>
        <cbc:LineID>{{ loop.index }}</cbc:LineID>
        <cbc:DocumentTypeCode>{{ doc.document_type_id }}</cbc:DocumentTypeCode>
        <cbc:ID>{{ doc.series }}-{{ doc.number }}</cbc:ID>
        <cac:AccountingCustomerParty>
            <cbc:CustomerAssignedAccountID>{{ doc.customer.number }}</cbc:CustomerAssignedAccountID>
            <cbc:AdditionalAccountID>{{ doc.customer.identity_document_type_id }}</cbc:AdditionalAccountID>
            <cac:Party>
                <cac:PartyLegalEntity>
                    <cbc:RegistrationName><![CDATA[{{ doc.customer.name }}]]></cbc:RegistrationName>
                </cac:PartyLegalEntity>
            </cac:Party>
        </cac:AccountingCustomerParty>
        {% if doc.document_type_id in ['07', '08'] and doc.note %}
        <cac:BillingReference>
            <cac:InvoiceDocumentReference>
                <cbc:ID>{{ doc.note.affected_series }}-{{ doc.note.affected_number }}</cbc:ID>
                <cbc:DocumentTypeCode>{{ doc.note.affected_document_type_id }}</cbc:DocumentTypeCode>
            </cac:InvoiceDocumentReference>
        </cac:BillingReference>
        {% endif %}
        {% if doc.perception %}
        <sac:SUNATPerceptionSummaryDocumentReference>
            <cbc:ID>{{ doc.perception.internal_id }}</cbc:ID>
            <sac:SUNATPerceptionAppliedAmount currencyID="PEN">{{ doc.perception.amount }}</sac:SUNATPerceptionAppliedAmount>
        </sac:SUNATPerceptionSummaryDocumentReference>
        {% endif %}
        <sac:Status>
            <cbc:ConditionCode>{{ doc.status or '1' }}</cbc:ConditionCode>
        </sac:Status>
        <sac:TotalAmount currencyID="{{ doc.currency_type_id }}">{{ doc.total }}</sac:TotalAmount>
        {% if doc.total_taxed | float > 0 %}
        <sac:BillingPayment>
            <cbc:PaidAmount currencyID="{{ doc.currency_type_id }}">{{ doc.total_taxed }}</cbc:PaidAmount>
            <cbc:InstructionID>01</cbc:InstructionID>
        </sac:BillingPayment>
        {% endif %}
        {% if doc.total_exonerated | float > 0 %}
        <sac:BillingPayment>
            <cbc:PaidAmount currencyID="{{ doc.currency_type_id }}">{{ doc.total_exonerated }}</cbc:PaidAmount>
            <cbc:InstructionID>02</cbc:InstructionID>
        </sac:BillingPayment>
        {% endif %}
        {% if doc.total_unaffected | float > 0 %}
        <sac:BillingPayment>
            <cbc:PaidAmount currencyID="{{ doc.currency_type_id }}">{{ doc.total_unaffected }}</cbc:PaidAmount>
            <cbc:InstructionID>03</cbc:InstructionID>
        </sac:BillingPayment>
        {% endif %}
        {% if doc.total_exportation | float > 0 %}
        <sac:BillingPayment>
            <cbc:PaidAmount currencyID="{{ doc.currency_type_id }}">{{ doc.total_exportation }}</cbc:PaidAmount>
            <cbc:InstructionID>04</cbc:InstructionID>
        </sac:BillingPayment>
        {% endif %}
        {% if doc.total_free | float > 0 %}
        <sac:BillingPayment>
            <cbc:PaidAmount currencyID="{{ doc.currency_type_id }}">{{ doc.total_free }}</cbc:PaidAmount>
            <cbc:InstructionID>05</cbc:InstructionID>
        </sac:BillingPayment>
        {% endif %}
        {% if doc.total_ivap | float > 0 %}
        <cac:TaxTotal>
            <cbc:TaxAmount currencyID="{{ doc.currency_type_id }}">{{ doc.total_ivap }}</cbc:TaxAmount>
            <cac:TaxSubtotal>
                <cbc:TaxAmount currencyID="{{ doc.currency_type_id }}">{{ doc.total_ivap }}</cbc:TaxAmount>
                <cac:TaxCategory>
                    <cac:TaxScheme>
                        <cbc:ID>1016</cbc:ID>
                        <cbc:Name>IVAP</cbc:Name>
                        <cbc:TaxTypeCode>VAT</cbc:TaxTypeCode>
                    </cac:TaxScheme>
                </cac:TaxCategory>
            </cac:TaxSubtotal>
        </cac:TaxTotal>
        {% endif %}
        {% if doc.total_igv | float > 0 %}
        <cac:TaxTotal>
            <cbc:TaxAmount currencyID="{{ doc.currency_type_id }}">{{ doc.total_igv }}</cbc:TaxAmount>
            <cac:TaxSubtotal>
                <cbc:TaxAmount currencyID="{{ doc.currency_type_id }}">{{ doc.total_igv }}</cbc:TaxAmount>
                <cac:TaxCategory>
                    <cac:TaxScheme>
                        <cbc:ID>1000</cbc:ID>
                        <cbc:Name>IGV</cbc:Name>
                        <cbc:TaxTypeCode>VAT</cbc:TaxTypeCode>
                    </cac:TaxScheme>
                </cac:TaxCategory>
            </cac:TaxSubtotal>
        </cac:TaxTotal>
        {% endif %}
        {% if doc.total_isc | float > 0 %}
        <cac:TaxTotal>
            <cbc:TaxAmount currencyID="{{ doc.currency_type_id }}">{{ doc.total_isc }}</cbc:TaxAmount>
            <cac:TaxSubtotal>
                <cbc:TaxAmount currencyID="{{ doc.currency_type_id }}">{{ doc.total_isc }}</cbc:TaxAmount>
                <cac:TaxCategory>
                    <cac:TaxScheme>
                        <cbc:ID>2000</cbc:ID>
                        <cbc:Name>ISC</cbc:Name>
                        <cbc:TaxTypeCode>EXC</cbc:TaxTypeCode>
                    </cac:TaxScheme>
                </cac:TaxCategory>
            </cac:TaxSubtotal>
        </cac:TaxTotal>
        {% endif %}
        {% if doc.total_other_taxes | float > 0 %}
        <cac:TaxTotal>
            <cbc:TaxAmount currencyID="{{ doc.currency_type_id }}">{{ doc.total_other_taxes }}</cbc:TaxAmount>
            <cac:TaxSubtotal>
                <cbc:TaxAmount currencyID="{{ doc.currency_type_id }}">{{ doc.total_other_taxes }}</cbc:TaxAmount>
                <cac:TaxCategory>
                    <cac:TaxScheme>
                        <cbc:ID>9999</cbc:ID>
                        <cbc:Name>OTROS</cbc:Name>
                        <cbc:TaxTypeCode>OTH</cbc:TaxTypeCode>
                    </cac:TaxScheme>
                </cac:TaxCategory>
            </cac:TaxSubtotal>
        </cac:TaxTotal>
        {% endif %}
        {% if doc.total_plastic_bag_taxes | float > 0 %}
        <cac:TaxTotal>
            <cbc:TaxAmount currencyID="{{ doc.currency_type_id }}">{{ doc.total_plastic_bag_taxes }}</cbc:TaxAmount>
            <cac:TaxSubtotal>
                <cbc:TaxAmount currencyID="{{ doc.currency_type_id }}">{{ doc.total_plastic_bag_taxes }}</cbc:TaxAmount>
                <cac:TaxCategory>
                    <cac:TaxScheme>
                        <cbc:ID>7152</cbc:ID>
                        <cbc:Name>ICBPER</cbc:Name>
                        <cbc:TaxTypeCode>OTH</cbc:TaxTypeCode>
                    </cac:TaxScheme>
                </cac:TaxCategory>
            </cac:TaxSubtotal>
        </cac:TaxTotal>
        {% endif %}
    </sac:SummaryDocumentsLine>
    {% endfor %}
</SummaryDocuments>
