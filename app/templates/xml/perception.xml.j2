<?xml version="1.0" encoding="utf-8" standalone="no"?>
{#
  Plantilla UBL 2.0 Percepción (40) SUNAT Perú
  Fiel traducción de perception.blade.php de CoreFacturalo.

  Variables específicas:
    document.perception_type_id      → código del régimen (01, 02, 03)
    document.perception_percentage   → porcentaje de percepción
    document.total_perception        → total percibido PEN
    document.total_amount            → total facturado PEN
    document.customer                → cliente
      {number, identity_document_type_id, name}
    document.documents               → documentos relacionados:
      {series, number, document_type_id, date_of_issue, total_amount,
       currency_type_id, total_perception, date_of_perception,
       net_total, exchange_rate_info: {exchange_amount, exchange_date}}
      payments: [{date, amount}]
#}
<Perception
    xmlns="urn:sunat:names:specification:ubl:peru:schema:xsd:Perception-1"
    xmlns:cac="urn:oasis:names:specification:ubl:schema:xsd:CommonAggregateComponents-2"
    xmlns:cbc="urn:oasis:names:specification:ubl:schema:xsd:CommonBasicComponents-2"
    xmlns:ds="http://www.w3.org/2000/09/xmldsig#"
    xmlns:ext="urn:oasis:names:specification:ubl:schema:xsd:CommonExtensionComponents-2"
    xmlns:sac="urn:sunat:names:specification:ubl:peru:schema:xsd:SunatAggregateComponents-1"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
    <ext:UBLExtensions>
        <ext:UBLExtension>
            <ext:ExtensionContent/>
        </ext:UBLExtension>
    </ext:UBLExtensions>
    <cbc:UBLVersionID>2.0</cbc:UBLVersionID>
    <cbc:CustomizationID>1.0</cbc:CustomizationID>
    <cac:Signature>
        <cbc:ID>{{ company.signature_uri or 'IDFirma' }}</cbc:ID>
        <cbc:Note>{{ company.signature_note or 'Empresa emisora' }}</cbc:Note>
        <cac:SignatoryParty>
            <cac:PartyIdentification>
                <cbc:ID>{{ company.legal_number }}</cbc:ID>
            </cac:PartyIdentification>
            <cac:PartyName>
                <cbc:Name><![CDATA[{{ company.trade_name }}]]></cbc:Name>
            </cac:PartyName>
        </cac:SignatoryParty>
        <cac:DigitalSignatureAttachment>
            <cac:ExternalReference>
                <cbc:URI>#{{ company.signature_uri or 'IDFirma' }}</cbc:URI>
            </cac:ExternalReference>
        </cac:DigitalSignatureAttachment>
    </cac:Signature>
    <cbc:ID>{{ document.series }}-{{ document.number }}</cbc:ID>
    <cbc:IssueDate>{{ document.date_of_issue }}</cbc:IssueDate>
    <cbc:DocumentCurrencyCode>{{ document.currency_type_id }}</cbc:DocumentCurrencyCode>
    <sac:SUNATPerceptionSystemCode>{{ document.perception_type_id }}</sac:SUNATPerceptionSystemCode>
    <sac:SUNATPerceptionPercent>{{ document.perception_percentage }}</sac:SUNATPerceptionPercent>
    {% if document.note %}
    <cbc:Note>{{ document.note }}</cbc:Note>
    {% endif %}
    <cbc:TotalInvoiceAmount currencyID="PEN">{{ document.total_amount }}</cbc:TotalInvoiceAmount>
    <sac:SUNATTotalCashed currencyID="PEN">{{ document.total_perception }}</sac:SUNATTotalCashed>
    <cac:AgentParty>
        <cac:PartyIdentification>
            <cbc:ID schemeID="6">{{ company.legal_number }}</cbc:ID>
        </cac:PartyIdentification>
        <cac:PartyName>
            <cbc:Name><![CDATA[{{ company.trade_name }}]]></cbc:Name>
        </cac:PartyName>
        <cac:PostalAddress>
            <cbc:ID>{{ document.establishment.district_id }}</cbc:ID>
            <cbc:StreetName><![CDATA[{{ document.establishment.address }}]]></cbc:StreetName>
            <cbc:CitySubdivisionName>{{ document.establishment.urbanization or '-' }}</cbc:CitySubdivisionName>
            <cbc:CityName>{{ document.establishment.province }}</cbc:CityName>
            <cbc:CountrySubentity>{{ document.establishment.department }}</cbc:CountrySubentity>
            <cbc:District>{{ document.establishment.district }}</cbc:District>
            <cac:Country>
                <cbc:IdentificationCode>{{ document.establishment.country_id or 'PE' }}</cbc:IdentificationCode>
            </cac:Country>
        </cac:PostalAddress>
        <cac:PartyLegalEntity>
            <cbc:RegistrationName><![CDATA[{{ company.legal_name }}]]></cbc:RegistrationName>
        </cac:PartyLegalEntity>
    </cac:AgentParty>
    <cac:ReceiverParty>
        <cac:PartyIdentification>
            <cbc:ID schemeID="{{ document.customer.identity_document_type_id }}">{{ document.customer.number }}</cbc:ID>
        </cac:PartyIdentification>
        <cac:PartyLegalEntity>
            <cbc:RegistrationName><![CDATA[{{ document.customer.name }}]]></cbc:RegistrationName>
        </cac:PartyLegalEntity>
    </cac:ReceiverParty>
    {% for doc in document.documents %}
    <sac:SUNATPerceptionDocumentReference>
        <cbc:ID schemeID="{{ doc.document_type_id }}">{{ doc.series }}-{{ doc.number }}</cbc:ID>
        <cbc:IssueDate>{{ doc.date_of_issue }}</cbc:IssueDate>
        <cbc:TotalInvoiceAmount currencyID="{{ doc.currency_type_id }}">{{ doc.total_amount }}</cbc:TotalInvoiceAmount>
        {% for pago in doc.payments or [] %}
        <cac:Payment>
            <cbc:ID>{{ loop.index }}</cbc:ID>
            <cbc:PaidAmount currencyID="{{ doc.currency_type_id }}">{{ pago.amount }}</cbc:PaidAmount>
            <cbc:InstructionID>01</cbc:InstructionID>
            <cbc:PaidDate>{{ pago.date }}</cbc:PaidDate>
        </cac:Payment>
        {% endfor %}
        <sac:SUNATPerceptionInformation>
            <sac:SUNATPerceptionAmount currencyID="PEN">{{ doc.total_perception }}</sac:SUNATPerceptionAmount>
            <sac:SUNATPerceptionDate>{{ doc.date_of_perception }}</sac:SUNATPerceptionDate>
            <sac:SUNATNetTotalCashed currencyID="PEN">{{ doc.net_total }}</sac:SUNATNetTotalCashed>
            {% if doc.exchange_rate_info %}
            <cac:ExchangeRate>
                <cbc:SourceCurrencyCode>{{ doc.currency_type_id }}</cbc:SourceCurrencyCode>
                <cbc:TargetCurrencyCode>PEN</cbc:TargetCurrencyCode>
                <cbc:CalculationRate>{{ doc.exchange_rate_info.exchange_amount }}</cbc:CalculationRate>
                <cbc:Date>{{ doc.exchange_rate_info.exchange_date }}</cbc:Date>
            </cac:ExchangeRate>
            {% endif %}
        </sac:SUNATPerceptionInformation>
    </sac:SUNATPerceptionDocumentReference>
    {% endfor %}
</Perception>
