# ---------------------------------------------------------------------------
# Aplicación
# ---------------------------------------------------------------------------
APP_NAME=sunat-fastapi
APP_VERSION=0.1.0
SECRET_KEY=cambia-esto-en-produccion-genera-con-openssl-rand-hex-32

# Entorno SUNAT: "demo" | "prod"
SUNAT_MODE=demo

# Logging: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# Servidor
# ---------------------------------------------------------------------------
API_PORT=8000
WEB_CONCURRENCY=4

# ---------------------------------------------------------------------------
# Storage
# ---------------------------------------------------------------------------
STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=/app/storage

# ---------------------------------------------------------------------------
# Base de datos — PostgreSQL
# En Docker Compose el host es el nombre del servicio: 'postgres'
# Para desarrollo local sin Docker: postgresql://user:pass@localhost:5432/sunat
# ---------------------------------------------------------------------------
POSTGRES_DB=sunat
POSTGRES_USER=sunat
POSTGRES_PASSWORD=cambia_esta_clave_segura
POSTGRES_PORT=5432

DATABASE_URL=postgresql://sunat:cambia_esta_clave_segura@postgres:5432/sunat

# ---------------------------------------------------------------------------
# Redis (fase 2: tickets y caché de sesiones)
# En Docker Compose el host es el nombre del servicio: 'redis'
# ---------------------------------------------------------------------------
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# ---------------------------------------------------------------------------
# Traefik (producción)
# ---------------------------------------------------------------------------
TRAEFIK_HOST=api.tudominio.com
